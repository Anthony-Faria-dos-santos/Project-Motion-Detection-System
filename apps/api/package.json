{
  "name": "@motionops/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch -r ./env.cjs src/index.ts",
    "build": "tsc",
    "start": "node -r ./env.cjs dist/index.js",
    "lint": "eslint src/ --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:push:test-schema": "node scripts/db-push-test-schema.cjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx -r ./env.cjs prisma/seed.ts",
    "db:seed:demo": "tsx -r ./env.cjs prisma/seed-demo.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/supabase-js": "^2.49.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.10.0",
    "socket.io": "^4.8.0",
    "speakeasy": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
