# Public API base URL consumed by the Next.js client bundle.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Observability - Sentry (optional)
# Public DSN, embedded in the client bundle. Empty disables the SDK.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (falls back to NEXT_PUBLIC_SENTRY_DSN when unset).
SENTRY_DSN=
# Used by withSentryConfig at build time to upload source maps. CI-only.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
